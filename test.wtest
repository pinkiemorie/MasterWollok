import recetas.*
import chefs.*
import concurso.*

describe "grupo de test necesarios" {
  test "La Paella con mariscos otorga 8 puntos" {
    paella.ponerMariscos()

    assert.equals(8, paella.puntuacion())
  }

  test "El risotto de hongos otorga 16 puntos en primavera" {
    risotto.cambiarIngredientePrincipal(hongo)
    hongo.empezarPrimavera()

    assert.equals(16, risotto.puntuacion())
  }

  test "Paulina obtiene 20 puntos al cocinar Ensalada" {
    paulina.cocinar(ensalada)

    assert.equals(20, paulina.puntuacion())
  }

  test "Remy obtiene 21 puntos al cocinar risotto de hongos con ratatouille cuando es primavera" {
    risotto.cambiarIngredientePrincipal(hongo)
    hongo.empezarPrimavera()
    remy.cocinar(risotto)

    assert.equals(21, remy.puntuacion())
  }

  test "Christof aprende a hacer ensalada, pero no puede cocinarla" {
    christof.aprender(ensalada)

    assert.notThat(christof.puedeCocinar(ensalada))
  }

  test "Christof aprende risotto y luego ensalada. Christof olvida risotto" {
    christof.aprender(risotto)
    christof.aprender(ensalada)

    assert.notEquals(risotto, christof.recetasConocidas())
  }

  test "Al inicio, hay dos concursantes que pueden cocinar risotto" {
    assert.equals(2, concurso.cantChefsQuePuedenCocinar(risotto))
  }

  test "La receta vegetariana con más puntos es el risotto de hongos" {
    assert.equals(risotto, concurso.recetaVegetarianaConMasPuntos())
  }

  test "Preparar concurso, todos aprenden y cocinen paella. La ganadora es Paulina" {
    concurso.prepararConcurso()
    concurso.concursantesAprendenReceta(paella)
    concurso.concursantesCocinanReceta(paella)

    assert.equals(paulina, concurso.ganador())
  }
}